{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedDeclarations": false,
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "src",
    "bin.mjs"
  ],
  "exclude": [
    "dist",
    ".next",
    "out"
  ]
}
